API_V1_PREFIX=/api/v1
SECRET_KEY=change-me-super-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=720
PLATFORM_ADMIN_KEY=change-platform-key
TENANT_SECRET_KEY=replace-with-random-secret-seed

POSTGRES_USER=voiceops
